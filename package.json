{
  "name": "opencode-skill-finder",
  "version": "2.1.1",
  "description": "OpenCode plugin that watches your task context, searches 7 skill marketplaces, caches locally with FTS5, and auto-recommends relevant skills.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "default": "./dist/api.js"
    }
  },
  "bin": {
    "skill-finder": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "postinstall": "node ./scripts/postinstall.mjs",
    "postupdate": "node ./scripts/postinstall.mjs"
  },
  "keywords": [
    "opencode",
    "plugin",
    "skills",
    "marketplace"
  ],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/brain-orch/skill-finder"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.17.0",
    "zod": "4.1.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.0",
    "better-sqlite3": "^12.0.0",
    "typescript": "^7.0.0",
    "vitest": "^4.0.0"
  }
}
